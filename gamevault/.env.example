# ═══════════════════════════════════════════════════════════════
# SaveState — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# Variables prefixed with EXPO_PUBLIC_ are accessible at runtime.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Coach (OpenRouter) ──────────────────────────────────────
AI_COACH_API_KEY=sk-or-v1-...
AI_COACH_MODEL=google/gemma-2-9b-it:free
AI_COACH_BASE_URL=https://openrouter.ai/api/v1

# ── Push Notifications (Firebase V1) ──────────────────────────
FCM_PROJECT_ID=your-project-id
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# ── Analytics (PostHog) ───────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Brand ─────────────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=SaveState
