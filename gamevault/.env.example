# ═══════════════════════════════════════════════════════════════
# SaveState — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# Variables prefixed with EXPO_PUBLIC_ are accessible at runtime.
# ═══════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────
# Required for all API calls and authentication
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Coach (OpenAI) ─────────────────────────────────────────
# Used by the ai-coach Supabase Edge Function
OPENAI_API_KEY=sk-your-openai-api-key

# ── Error Tracking (Sentry) ───────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── Analytics (PostHog) ───────────────────────────────────────
EXPO_PUBLIC_POSTHOG_KEY=phc_your_posthog_api_key
EXPO_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ── Push Notifications (Firebase) ─────────────────────────────
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# ── Google Cloud ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-google-cloud-project
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# ── EAS Build ─────────────────────────────────────────────────
EAS_PROJECT_ID=your-eas-project-id
